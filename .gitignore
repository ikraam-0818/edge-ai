# Virtual environments
env/
venv/
.env

# AWS Certificates
certs/

# Model weights — block large PyTorch/ONNX files
models/**/*.pt
models/**/*.onnx
# Allow NCNN weights (.bin + .param) — these are small enough for Git (~12MB)
!models/yolo11n_ncnn/*.bin
!models/yolo11n_ncnn/*.param

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

runs/
yolo11n.pt

# Runtime / generated files
*.db
*.sqlite
image.png

.ssh
.cache
.copilot
.gemini
.streamlit
.vscode-server
.venv